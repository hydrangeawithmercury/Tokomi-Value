{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tokomi Value",
  "version": "0.1.0",
  "identifier": "com.tokomi.value",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Tokomi Value",
        "width": 500,
        "height": 664,
        "minWidth": 360,
        "minHeight": 480,
        "resizable": true,
        "alwaysOnTop": true,
        "decorations": true,
        "transparent": false,
        "skipTaskbar": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico"
    ]
  }
}
